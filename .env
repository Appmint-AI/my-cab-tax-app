# =============================================================================
# MCTUSA Environment Variables
# =============================================================================

# --- REQUIRED ---

# PostgreSQL connection string (Neon serverless)
DATABASE_URL=postgresql://neondb_owner:npg_KlvAHnXJ8M9V@ep-silent-grass-afh3fxik-pooler.c-2.us-west-2.aws.neon.tech/mctusa?sslmode=require

# Express session secret (generate a random string: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-secret

# Server port
PORT=5000

# --- AUTH0 (Required for authentication) ---
# Uncomment and fill these when you have Auth0 credentials:
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_CLIENT_ID=your-auth0-client-id
# AUTH0_CLIENT_SECRET=your-auth0-client-secret

# --- STRIPE (Required for subscription billing) ---
# Uncomment and fill these when you have Stripe credentials:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRO_PRICE_ID=price_...

# --- GOOGLE GEMINI AI (Required for receipt OCR) ---
# Uncomment and fill when you have a Gemini API key:
# AI_INTEGRATIONS_GEMINI_API_KEY=your-gemini-api-key

# --- OPTIONAL ---

# App URL (defaults to http://localhost:5000 in dev)
# APP_URL=https://your-domain.com

# Admin email (defaults to founder@mycabtax.com)
# ADMIN_EMAIL=admin@example.com

# Resend email service
# RESEND_FROM_EMAIL=noreply@mycabtax.com

# Avalara tax rate provider (optional fallback)
# AVALARA_API_KEY=
# AVALARA_ACCOUNT_ID=
# AVALARA_ENVIRONMENT=sandbox

# Node environment
NODE_ENV=development
